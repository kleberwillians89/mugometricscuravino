# ===== Frontend (Vite) =====
# Em produção/Render, aponte para a URL pública da API.
VITE_API_BASE=http://localhost:8000
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_DEFAULT_CLIENT_ID=YOUR_ROOVE_CLIENT_ID

# ===== Backend (FastAPI/server) =====
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Em produção, use o domínio público do frontend no Render.
ALLOW_ORIGIN=http://localhost:5173,http://localhost:5174

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Meta Token lifecycle
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
# Em produção/Render, use https://SEU-BACKEND.onrender.com/api/oauth/meta/callback
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/meta/callback
TOKEN_ENCRYPTION_KEY=replace_with_32+_chars_key
SHOPIFY_APP_SECRET=YOUR_SHOPIFY_APP_SECRET
SHOPIFY_ROOVE_SHOP_DOMAIN=roove.myshopify.com
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID
# Prioridade recomendada no Render/produção:
GA4_SERVICE_ACCOUNT_JSON_BASE64=BASE64_DO_JSON_DA_SERVICE_ACCOUNT
# Fallback inline:
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Somente local/dev:
# GA4_CREDENTIALS_PATH=/absolute/path/to/ga4-service-account.json

# Cron security
CRON_SECRET=replace_with_long_random_secret

# Optional
IG_MEDIA_BUCKET=ig-media
CLIENT_USERS_TABLE=client_users
ALLOW_NO_AUTH=false
DEV_USER_ID=
ROOVE_CLIENT_ID=YOUR_ROOVE_CLIENT_ID

# Optional auto-bootstrap (local dev) to avoid reconnecting Meta every restart
META_BOOTSTRAP_PREFIXES=MUGO,ROOVE
MUGO_CLIENT_ID=
MUGO_IG_USER_ID=
MUGO_ACCESS_TOKEN=
MUGO_EXPIRES_AT=
ROOVE_IG_USER_ID=
ROOVE_ACCESS_TOKEN=
ROOVE_EXPIRES_AT=
