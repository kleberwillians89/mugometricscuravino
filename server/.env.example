SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Use uma chave forte e estável. Não compartilhar com o frontend.
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-secret

META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET

# Necessário para o fluxo OAuth existente. Em produção/Render use a URL pública da API.
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/meta/callback

# Protege endpoints de cron.
CRON_SECRET=change-me-to-a-long-random-secret

# Janela operacional do lifecycle de token.
META_TOKEN_REFRESH_WINDOW_DAYS=7
META_TOKEN_VALIDATE_WINDOW_HOURS=6

# Local/dev. Em produção substitua pelo domínio público do frontend no Render.
ALLOW_ORIGIN=http://localhost:5173,http://localhost:5174
ALLOW_NO_AUTH=false
DEV_USER_ID=
